defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

account        gmx
host           mail.gmx.net
port           465
from           timo.wolf@gmx.ch
user           timo.wolf@gmx.ch
passwordeval   secret-tool lookup service gmx-smtp user timo.wolf@gmx.ch
tls_starttls   off

account default : gmx